# Local FastAPI bridge. Cloudflare production must use the confirmed HTTPS API URL.
DOOH_API_BASE_URL=http://127.0.0.1:8000
DOOH_API_TIMEOUT_MS=8000

# FastAPI-only administrator credentials. The username is fixed in server/app.py.
# Never expose the password or token secret through app-config.js.
DOOH_ADMIN_PASSWORD=
DOOH_ADMIN_TOKEN_SECRET=
